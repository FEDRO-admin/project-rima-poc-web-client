{
  "name": "project-rima-poc-web-client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test-ci": "ng test --watch=false --coverage",
    "prepare": "husky",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "lint": "ng lint",
    "type:check": "tsc --noEmit",
    "i18n:extract": "transloco-keys-manager extract",
    "i18n:find": "transloco-keys-manager find --translations-path public/i18n --emit-error-on-extra-keys"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular-architects/ngrx-toolkit": "^21.0.1",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@arcgis/core": "^5.0.16",
    "@arcgis/map-components": "^5.0.16",
    "@jsverse/transloco": "^8.3.0",
    "@ngrx/signals": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@jsverse/transloco-keys-manager": "^8.1.0",
    "@ngrx/eslint-plugin": "^21.1.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-rxjs-angular-x": "^1.0.1",
    "eslint-plugin-rxjs-x": "^1.0.2",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
}
